#!/usr/bin/env sh

MSG=$(cat "$1")

# Bypass automatic commits
echo "$MSG" | grep -qE '^(Merge|Revert|fixup!|squash!)' && exit 0

# Validate conventional commit format (scope is optional)
PATTERN='^(feat|fix|docs|chore|refactor|test|style|ci|perf|revert)(\([a-z0-9_/-]+\))?: .{1,72}$'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ERROR: Invalid commit message format."
  echo ""
  echo "  Got: $MSG"
  echo ""
  echo "  Required format:  type(scope): description"
  echo "                or  type: description"
  echo ""
  echo "  Valid types: feat, fix, docs, chore, refactor, test, style, ci, perf, revert"
  echo "  Scope: optional, lowercase, alphanumeric (e.g. map, pipeline, schema)"
  echo "  Description: max 72 characters"
  echo ""
  echo "  Examples:"
  echo "    feat(map): add route animation"
  echo "    fix: correct coordinate order"
  echo "    docs(schema): update journey fields"
  echo "    chore: update dependencies"
  echo ""
  exit 1
fi

# Reject AI authorship attribution phrases (not product names like "Claude Code")
AI_PATTERN='co-authored-by:.*claude|generated with claude|ai-generated|🤖'

if echo "$MSG" | grep -iqE "$AI_PATTERN"; then
  echo ""
  echo "  ERROR: Commit message contains AI authorship references."
  echo ""
  echo "  Remove any of the following from the message:"
  echo "    Co-Authored-By: Claude, Generated with Claude,"
  echo "    AI-generated, 🤖"
  echo ""
  exit 1
fi

exit 0
