# Moto Routes v4 - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# =============================================================================
# SUPABASE
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Project Settings > API

# Project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Project API Key - anon/public key (starts with "eyJ...")
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# MAPBOX
# =============================================================================
# Get your token from: https://account.mapbox.com/access-tokens/
# Create a token with:
#   - Scopes: styles:read, fonts:read
#   - URL restrictions: add your domain for production

# Public access token (starts with "pk.")
VITE_MAPBOX_ACCESS_TOKEN=

# =============================================================================
# OPTIONAL - Development
# =============================================================================

# Enable debug mode (shows additional logging)
# VITE_DEBUG=true

# API base URL override (for local development)
# VITE_API_URL=http://localhost:3000
